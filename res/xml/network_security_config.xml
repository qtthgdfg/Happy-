<!-- res/xml/network_security_config.xml -->
<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext for all domains (needed for HTTP connections) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- Trust system certificates -->
            <certificates src="system" />
            <!-- Also trust user installed certificates -->
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    
    <!-- Allow connections to mining pools -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">pool.supportxmr.com</domain>
        <domain includeSubdomains="true">pool.minexmr.com</domain>
        <domain includeSubdomains="true">xmrpool.eu</domain>
        <domain includeSubdomains="true">cloudfront.net</domain>
        <domain includeSubdomains="true">cloudflare.net</domain>
        <domain includeSubdomains="true">fastly.net</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
    
    <!-- Debug overrides for testing -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
